# 2009scape save-sync repo — track progress/save data only.
# The static game cache ships with the install (same on every PC) and its
# files can exceed GitHub's 100 MB limit, so never sync it.
cache/

# Logs and transient files
logs/
*.log

# Timestamped backups made before edits (not worth syncing)
*.bak*

# custom-items/ is tracked — full emberblade assets (models/textures/cache) backed up per user request.
